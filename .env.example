# Configuración
# (por defecto: 3000)
PORT=3000

# Clave de API de OpenAI
# Si se define sobrescribe la configurada desde el dashboard
OPENAI_API_KEY=

# Modelo de chat
# (por defecto: gpt-4o-mini)
OPENAI_MODEL=...

# Modelo de embeddings
# (por defecto: text-embedding-3-small)
OPENAI_EMBEDDING_MODEL=...

# Configuración de Supabase
SUPABASE_URL=...
SUPABASE_SERVICE_KEY=

# Orígenes permitidos para CORS:
# - Lista de URLs separadas por comas
# - Vacío: abierto (para desarrollo)
ALLOWED_ORIGINS=

# Tamaño máximo de subida de archivos en MB
# (por defecto: 5)
UPLOAD_MAX_SIZE_MB=