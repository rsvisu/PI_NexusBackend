# Configuración
# (por defecto: 3000)
PORT=3000

# Clave de API de OpenAI
OPENAI_API_KEY=sk-XXX...
# (por defecto: gpt-4o-mini)
OPENAI_MODEL=...    

# Configuración de Supabase
SUPABASE_URL=...
SUPABASE_SERVICE_KEY=

# Orígenes permitidos para CORS:
# - Lista de URLs separadas por comas
# - Vacío: abierto (para desarrollo) 
ALLOWED_ORIGINS=

# Máximo de mensajes al chat por IP por minuto
# (por defecto: 10)
CHAT_RATE_LIMIT_MAX=           